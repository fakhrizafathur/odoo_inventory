<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List -->
    <record id="view_stock_in_tree" model="ir.ui.view">
        <field name="name">inventory.stock.in.tree</field>
        <field name="model">inventory.stock.in</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="product_id"/>
                <field name="qty"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="view_stock_in_form" model="ir.ui.view">
        <field name="name">inventory.stock.in.form</field>
        <field name="model">inventory.stock.in</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="date"/>
                        <field name="product_id"/>
                        <field name="qty"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_stock_in" model="ir.actions.act_window">
        <field name="name">Stock In</field>
        <field name="res_model">inventory.stock.in</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>