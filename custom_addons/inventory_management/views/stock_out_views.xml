<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_stock_out_tree" model="ir.ui.view">
        <field name="name">inventory.stock.out.tree</field>
        <field name="model">inventory.stock.out</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="product_id"/>
                <field name="qty"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_stock_out_form" model="ir.ui.view">
        <field name="name">inventory.stock.out.form</field>
        <field name="model">inventory.stock.out</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="date"/>
                        <field name="product_id"/>
                        <field name="qty"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_stock_out" model="ir.actions.act_window">
        <field name="name">Stock Out</field>
        <field name="res_model">inventory.stock.out</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>